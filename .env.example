# LLM Provider
# Supported values: openrouter, opencode-go
LLM_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenCode Go
OPENCODE_GO_API_KEY=your_opencode_go_api_key_here

# Optional: Default model for the selected provider
# Examples:
# - OpenRouter: anthropic/claude-sonnet-4
# - OpenCode Go: qwen3.5-plus
DEFAULT_MODEL=anthropic/claude-sonnet-4

# Browser
BROWSER_HEADLESS=false
CHROME_PROFILE_PATH=

# Database (PostgreSQL)
DATABASE_URL=postgresql://root:root@45.159.221.130:7777/root

# Logging
LOG_LEVEL=info
